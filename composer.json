{
  "name": "responseone/security-guard-saas",
  "description": "Enterprise Security Guard Management SaaS built with Laravel, Livewire, Tailwind, Redis queues, and multi-tenant architecture.",
  "type": "project",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12.0",
    "livewire/livewire": "^3.0",
    "laravel/sanctum": "^4.0",
    "spatie/laravel-permission": "^6.0",
    "stancl/tenancy": "^3.9",
    "spatie/laravel-activitylog": "^4.8",
    "barryvdh/laravel-dompdf": "^3.0",
    "bacon/bacon-qr-code": "^3.1",
    "maatwebsite/excel": "^3.1",
    "laravel/reverb": "^1.10"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "laravel/pint": "^1.13",
    "phpunit/phpunit": "^11.0",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ]
  }
}
